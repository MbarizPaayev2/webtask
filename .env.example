# Layihə kökündə .env yaradın:  copy .env.example .env

FLASK_SECRET_KEY=oz-uzun-tesadufi-mətn

# PostgreSQL (mütləq) — məs. postgresql://user:pass@localhost:5432/aviakassa
DATABASE_URL=

# --- Təhlükəsizlik labı (default: AÇIQ) ---
# WEBSEC_LAB=1  →  zəif SQL (DEV_INSECURE_SQL) + parol bypass (DEV_AUTH_BYPASS) aktiv
# WEBSEC_LAB=0  →  yalnız aşağıdakı açıq sətirlərlə lab aktiv olsun
# WEBSEC_LAB=0
# DEV_INSECURE_SQL=1
# DEV_AUTH_BYPASS=1
